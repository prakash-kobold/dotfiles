# User specific environment and startup programs

# homebrew
if [ -d "/opt/homebrew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export PATH="${HOME}/bin:${HOME}/.local/bin:${PATH}"

# zoxide
export _ZO_DATA_DIR=$HOME/.local/share
